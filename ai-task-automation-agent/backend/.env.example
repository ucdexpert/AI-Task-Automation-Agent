# ==========================================
# AI Task Automation Agent - Backend
# ==========================================
# Copy this file to .env and fill in your values

# LLM (Groq) - Required
GROQ_API_KEY=your_groq_api_key_here

# Database - Required
# For development: SQLite
# DATABASE_URL=sqlite:///./agent.db
# For production: PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/task_automation

# JWT - Required (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRE_HOURS=24

# Email Configuration - Optional (for email tool)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Google Calendar - Optional
GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials_json
