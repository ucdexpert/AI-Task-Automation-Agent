# ==========================================
# AI Task Automation Agent - Backend
# ==========================================
# Copy this file to .env and fill in your values

# 1. Application Settings
APP_NAME="AI Task Automation Agent"
APP_ENV=development # development, production
DEBUG=True
LOG_LEVEL=INFO

# 2. Database - Required
# For development: SQLite
# DATABASE_URL=sqlite:///./agent.db
# For production: PostgreSQL (Recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/task_automation

# 3. Security & Auth - Required
# Generate a secure key with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRE_HOURS=24

# 4. LLM (Groq) - Required
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# 5. CORS Settings (Optional - For Frontend Connection)
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# 6. Email Configuration - Optional (For email tool)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# 7. File Storage - Optional
DOCUMENTS_DIR=documents

# 8. Google Calendar - Optional
GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials_json

# 9. Rate Limiting - Optional
RATE_LIMIT_PER_MINUTE=60
